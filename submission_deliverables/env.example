# Environment template for local assessment demo.
# Copy to .env only if needed. Do not commit real secrets.

# Optional OpenAI STT provider. The default local demo does not require this.
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1

# Local faster-whisper STT settings for Q1/Q3 web microphone transcription.
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_BEST_OF=5
FASTER_WHISPER_VAD_FILTER=true
FASTER_WHISPER_CONDITION_ON_PREVIOUS_TEXT=true

# Low-latency Q4 mode. This is intentionally faster and less accurate.
FASTER_WHISPER_FAST_MODEL=tiny.en
FASTER_WHISPER_FAST_LANGUAGE=en
FASTER_WHISPER_FAST_BEAM_SIZE=1
FASTER_WHISPER_FAST_BEST_OF=1
FASTER_WHISPER_FAST_VAD_FILTER=false

# Local web ports used by the demo.
WEB_CALLING_HOST=127.0.0.1
WEB_CALLING_PORT=8766
Q4_PANEL_HOST=127.0.0.1
Q4_PANEL_PORT=8775

